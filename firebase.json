{
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099,
      "HOST": "127.0.0.1" },
    "firestore": {
      "port": 8080,
      "HOST":"127.0.0.1" },
    "ui": {
      "enabled": true,
      "port": 4000,
      "HOST":"127.0.0.1" },
    "singleProjectMode": true,
    "functions": {
      "port": 5001,
      "HOST":"127.0.0.1" }
  }
}
